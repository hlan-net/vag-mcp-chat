# ── FastMCP JWT signing key ───────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MCP_JWT_SECRET=changeme_generate_a_real_32_byte_hex_value

# ── Fernet key for encrypting stored VW tokens at rest ────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MCP_FERNET_KEY=changeme_generate_a_real_fernet_key

# ── Public base URL of the MCP server (used in OAuth metadata) ────────────────
MCP_BASE_URL=http://localhost:8000

# ── VW EU Data Act OIDC credentials ──────────────────────────────────────────
# Register your application at:
#   https://eu-data-act.drivesomethinggreater.com
#
# The OIDC well-known document is at:
#   https://eu-data-act.drivesomethinggreater.com/.well-known/openid-configuration
#
# Set the redirect URI in your VW application registration to:
#   http://localhost:8000/auth/callback
VW_OIDC_ISSUER=https://eu-data-act.drivesomethinggreater.com
VW_OIDC_CLIENT_ID=your_vw_client_id_here
VW_OIDC_CLIENT_SECRET=your_vw_client_secret_here
VW_OIDC_SCOPES=openid profile email vehicle:read

# ── Default VIN (optional; used when the agent doesn't specify one) ───────────
VW_DEFAULT_VIN=

# ── Data polling interval in seconds (default 840 = 14 min) ──────────────────
VW_DATA_POLL_INTERVAL_SECONDS=840

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Agent connects to the MCP server at this URL ─────────────────────────────
MCP_SERVER_URL=http://localhost:8000

# ── Local callback port for the agent's PKCE redirect ────────────────────────
AGENT_CALLBACK_PORT=9000
